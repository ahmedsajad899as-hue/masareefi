# Required — set these in Railway dashboard under Variables tab
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/masareefi
SECRET_KEY=replace-with-long-random-string-min-32-chars
OPENAI_API_KEY=sk-your-openai-key-or-sk-placeholder

# Allow all origins in production (Railway domain changes, easier to allow all)
ALLOWED_ORIGINS=*

# Optional
DEBUG=False
